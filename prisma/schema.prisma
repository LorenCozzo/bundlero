generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model QuantityBundle {
  id                          String   @id @default(cuid())
  shop                        String
  name                        String
  isActive                    Boolean  @default(true)
  applyTo                     String   @default("ALL")
  productId                   String?
  widgetTitle                 String   @default("Elige un paquete y ahorra")
  primaryColor                String   @default("#16A34A")
  combinesWithProductDiscounts Boolean  @default(false)
  discountGid                 String?

  // Configuración extra (UX rediseño)
  discountName       String?
  styleLayout        Int     @default(0)
  cornerRadius       Int     @default(16)
  spacing            Int     @default(8)
  cardBg             String  @default("#FFFFFF")
  selectedBg         String  @default("#F0FFF4")
  borderColor        String  @default("#16A34A")
  titleColor         String  @default("#111827")
  subtitleColor      String  @default("#6B7280")
  priceColor         String  @default("#111827")
  originalPriceColor String  @default("#9CA3AF")
  labelBg            String  @default("#BBF7D0")
  labelTextColor     String  @default("#111827")
  badgeBg            String  @default("#111827")
  badgeTextColor     String  @default("#FFFFFF")
  fontFamily         String  @default("inherit")
  timerEnabled       Boolean @default(false)
  timerHours         Int     @default(9)
  timerText          String  @default("¡Date prisa! Oferta expira en")

  tiers     Tier[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model Tier {
  id            String         @id @default(cuid())
  bundleId      String
  bundle        QuantityBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  quantity      Int
  label         String
  badge         String?
  discountType  String
  discountValue Float
  isPopular     Boolean        @default(false)
  position      Int            @default(0)

  // Campos nuevos UX
  subtitle  String?
  etiqueta  String?
  isDefault Boolean @default(false)
}

{
  "buildCommand": "npm run setup && npm run build",
  "outputDirectory": "build/client",
  "installCommand": "npm install",
  "functions": {
    "build/server/index.js": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/build/server/index.js" }
  ]
}
